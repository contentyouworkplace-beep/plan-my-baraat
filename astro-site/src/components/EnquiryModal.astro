<div id="enquiry-modal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-md items-center justify-center p-4">
  <div id="enquiry-panel" class="bg-white w-full max-w-md border border-[#E70D1D]/25 relative overflow-hidden">
    <button id="enquiry-close" type="button" class="absolute top-4 right-4 p-2 bg-black/5 text-black/60 hover:text-[#E70D1D] transition-colors z-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
    </button>

    <div id="enquiry-success" class="hidden p-10 text-center space-y-4">
      <div class="h-14 w-14 border border-[#E70D1D]/30 text-[#E70D1D] flex items-center justify-center mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12v0c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/></svg>
      </div>
      <h3 class="font-serif font-black text-xl text-black">Enquiry Sent!</h3>
      <p class="text-xs text-black/50 leading-relaxed">
        Your enquiry for the <span id="enquiry-success-pkg" class="font-bold text-black/80"></span> has been sent on WhatsApp. Our team will get back to you shortly.
      </p>
      <button id="enquiry-close-2" type="button" class="mt-2 h-11 px-6 bg-[#E70D1D] hover:bg-[#c40d1a] text-white text-xs font-extrabold uppercase tracking-widest transition-colors">
        Close
      </button>
    </div>

    <form id="enquiry-form" class="p-8 space-y-5">
      <div class="space-y-1">
        <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest">Enquire Now</span>
        <h3 id="enquiry-pkg-name" class="font-serif font-black text-xl text-black"></h3>
        <p class="text-xs text-black/50">Share your details and we'll reach out on WhatsApp.</p>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-black/50 font-bold tracking-widest">Your Name *</label>
        <input id="enquiry-name" type="text" placeholder="e.g. Rahul Sharma" required
          class="w-full bg-black/5 border border-black/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-[#E70D1D] text-black placeholder:text-black/30" />
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-black/50 font-bold tracking-widest">Event Date *</label>
        <input id="enquiry-date" type="date" required
          class="w-full bg-black/5 border border-black/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-[#E70D1D] text-black" />
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase text-black/50 font-bold tracking-widest">Phone Number *</label>
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-black/60 bg-black/5 border border-black/15 px-3 py-2.5">+91</span>
          <input id="enquiry-phone" type="tel" placeholder="9876543210" pattern="[6-9][0-9]{9}" maxlength="10" required
            class="flex-1 bg-black/5 border border-black/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-[#E70D1D] text-black placeholder:text-black/30" />
        </div>
      </div>

      <button type="submit" id="enquiry-submit"
        class="w-full h-12 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300 flex items-center justify-center gap-2.5 disabled:opacity-60">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        <span id="enquiry-submit-label">Send Enquiry on WhatsApp</span>
      </button>

      <p class="text-[10px] text-black/30 text-center">🔒 Your details are safe. We never share your information with third parties.</p>
    </form>
  </div>
</div>

<script>
  import { supabase, isSupabaseConfigured } from "../data/supabase";
  import { buildPackageWhatsAppLink } from "../data/whatsapp";

  const modal = document.getElementById("enquiry-modal")!;
  const form = document.getElementById("enquiry-form") as HTMLFormElement;
  const success = document.getElementById("enquiry-success")!;
  const pkgNameEl = document.getElementById("enquiry-pkg-name")!;
  const successPkgEl = document.getElementById("enquiry-success-pkg")!;
  const nameInput = document.getElementById("enquiry-name") as HTMLInputElement;
  const dateInput = document.getElementById("enquiry-date") as HTMLInputElement;
  const phoneInput = document.getElementById("enquiry-phone") as HTMLInputElement;
  const submitBtn = document.getElementById("enquiry-submit") as HTMLButtonElement;
  const submitLabel = document.getElementById("enquiry-submit-label")!;

  const today = new Date().toISOString().split("T")[0];
  dateInput.min = today;

  let currentPackage = "";

  function openModal(packageName: string) {
    currentPackage = packageName;
    pkgNameEl.textContent = packageName;
    form.classList.remove("hidden");
    success.classList.add("hidden");
    form.reset();
    dateInput.min = today;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  document.querySelectorAll(".enquire-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const pkg = btn.getAttribute("data-package") || "";
      openModal(pkg);
    });
  });

  document.getElementById("enquiry-close")?.addEventListener("click", closeModal);
  document.getElementById("enquiry-close-2")?.addEventListener("click", closeModal);
  modal.addEventListener("click", closeModal);
  document.getElementById("enquiry-panel")?.addEventListener("click", (e) => e.stopPropagation());

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const name = nameInput.value.trim();
    const eventDate = dateInput.value;
    const phone = phoneInput.value.trim();

    if (!name || !eventDate || !/^[6-9]\d{9}$/.test(phone)) {
      return;
    }

    submitBtn.disabled = true;
    submitLabel.textContent = "Sending...";

    if (supabase && isSupabaseConfigured) {
      try {
        await supabase.from("crm_baraat_enquiries").insert([{
          customer_name: name,
          event_date: eventDate,
          mobile: phone,
          package_name: currentPackage,
          status: "New",
        }]);
      } catch (err) {
        console.error("Failed to save baraat enquiry to CRM", err);
      }
    }

    const link = buildPackageWhatsAppLink(name, phone, eventDate, currentPackage);
    window.open(link, "_blank");

    submitBtn.disabled = false;
    submitLabel.textContent = "Send Enquiry on WhatsApp";

    successPkgEl.textContent = currentPackage;
    form.classList.add("hidden");
    success.classList.remove("hidden");
  });
</script>
