---
import Layout from "../../layouts/Layout.astro";
import { BARAAT_KEYWORDS, getKeywordBySlug } from "../../data/baraatKeywords";
import { BARAAT_PACKAGES } from "../../data/packagesData";
import { WHATSAPP_NUMBER } from "../../data/whatsapp";
import { keywordIntro } from "../../data/baraatContentVariants";
import { getKeywordMeta } from "../../data/seoMeta";

export function getStaticPaths() {
  return BARAAT_KEYWORDS.map((k) => ({ params: { keyword: k.slug } }));
}

const { keyword } = Astro.params;
const kw = getKeywordBySlug(keyword!);
if (!kw) return Astro.redirect("/404");

const waText = encodeURIComponent(
  `Hi PlanMyBaraat! 🎊\n\nI'm interested in: ${kw.phrase}. Please share package details and availability.`
);
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;

const related = BARAAT_KEYWORDS.filter((k) => k.category === kw.category && k.slug !== kw.slug).slice(0, 6);

const meta = getKeywordMeta(kw);
---

<Layout title={meta.title} description={meta.description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-8 text-center space-y-4">
    <nav class="text-[10px] uppercase tracking-widest text-black/40 flex items-center justify-center gap-1.5">
      <a href="/" class="hover:text-[#E70D1D]">Home</a>
      <span>/</span>
      <a href="/baraat-management" class="hover:text-[#E70D1D]">Baraat Management</a>
      <span>/</span>
      <span class="text-black/70">{kw.category}</span>
    </nav>

    <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">{kw.category}</span>
    <h1 class="font-serif font-black text-2xl md:text-4xl text-black tracking-wide capitalize">{kw.phrase}</h1>

    <p class="text-black/60 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
      {keywordIntro(kw.slug, { phrase: kw.phrase, category: kw.category })}
    </p>

    <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
      Enquire on WhatsApp
    </a>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <div class="text-center space-y-1">
      <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Included In Our Packages</span>
      <h2 class="font-serif font-black text-2xl md:text-3xl text-black tracking-wide">Choose Your Royal Experience</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {BARAAT_PACKAGES.map((pkg) => (
        <div class="border border-black/10 p-6 bg-white shadow-sm">
          <h3 class="font-serif font-black text-lg text-black">{pkg.name}</h3>
          <span class="text-[10px] uppercase font-bold tracking-widest text-[#E70D1D]">{pkg.tagline}</span>
          <p class="text-xs text-black/50 mt-2 mb-4">{pkg.description}</p>
          <ul class="space-y-2">
            {pkg.features.slice(0, 4).map((f) => (
              <li class="flex items-start gap-2 text-xs text-black/70">
                <span class="text-[#E70D1D] mt-0.5">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  {related.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 space-y-4">
      <h2 class="font-serif font-black text-lg text-black tracking-wide">Related to {kw.category}</h2>
      <div class="flex flex-wrap gap-2">
        {related.map((r) => (
          <a href={`/baraat-management/${r.slug}`} class="text-xs px-3 py-1.5 border border-black/10 text-black/60 hover:border-[#E70D1D]/40 hover:text-[#E70D1D] transition-colors capitalize">
            {r.phrase}
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
