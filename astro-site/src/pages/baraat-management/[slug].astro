---
import Layout from "../../layouts/Layout.astro";
import { ALL_BARAAT_LOCATIONS, getLocationBySlug } from "../../data/baraatLocations";
import { BARAAT_KEYWORDS } from "../../data/baraatKeywords";
import { BARAAT_PACKAGES } from "../../data/packagesData";
import { WHATSAPP_NUMBER } from "../../data/whatsapp";
import { getSeoPageContent } from "../../data/seoContentEngine";

export function getStaticPaths() {
  const locationPaths = ALL_BARAAT_LOCATIONS.map((l) => ({ params: { slug: l.slug } }));
  const keywordPaths = BARAAT_KEYWORDS.map((k) => ({ params: { slug: k.slug } }));
  
  // Generate key city-specific categories
  const priorityCities = ALL_BARAAT_LOCATIONS.filter((l) => l.type === "city");
  const coreCategories = ["dj-truck-for-baraat", "dhol-for-wedding", "vintage-car-for-baraat", "safa-for-groom", "baraat-on-wheels"];
  const comboPaths = priorityCities.flatMap((city) =>
    coreCategories.map((cat) => ({
      params: { slug: `${cat}-${city.slug}` }
    }))
  );

  return [...locationPaths, ...keywordPaths, ...comboPaths];
}

const { slug } = Astro.params;
const content = getSeoPageContent(slug!);

if (!content) return Astro.redirect("/404");

const loc = getLocationBySlug(slug!);
const parent = loc && loc.parentCity ? ALL_BARAAT_LOCATIONS.find((l) => l.slug === loc.parentCity) : undefined;

const waText = encodeURIComponent(
  `Hi PlanMyBaraat! 🎊\n\nI'm looking for baraat package services for ${content.pageTitle}. Please share package details and availability.`
);
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;

const sections = [
  { eyebrow: "Local Operations", heading: "Baraat Operations & Logistics", body: content.localArea },
  { eyebrow: "What's Included", heading: "Baraat Package Features & Details", body: content.whatsIncluded },
  { eyebrow: "Why Choose Us", heading: "Gujarat's Professional Baraat Team", body: content.whyUs },
  { eyebrow: "Pricing", heading: "Baraat Package Pricing & Quotes", body: content.pricingGuidance },
  { eyebrow: "Planning", heading: "Procession Timing & Curfew Notes", body: content.planningNotes },
];

// Related links mesh
let relatedLinks: { label: string; href: string }[] = [];
if (loc) {
  if (loc.type === "city") {
    const childAreas = ALL_BARAAT_LOCATIONS.filter((a) => a.parentCity === loc.slug && a.type === "area");
    relatedLinks = childAreas.map((a) => ({ label: a.name, href: `/baraat-management/${a.slug}` }));
  } else if (loc.type === "area" && loc.parentCity) {
    const siblingAreas = ALL_BARAAT_LOCATIONS.filter(
      (a) => a.parentCity === loc.parentCity && a.type === "area" && a.slug !== loc.slug
    ).slice(0, 15);
    relatedLinks = siblingAreas.map((a) => ({ label: a.name, href: `/baraat-management/${a.slug}` }));
  }
} else {
  const priorityCities = ALL_BARAAT_LOCATIONS.filter((l) => l.type === "city").slice(0, 10);
  relatedLinks = priorityCities.map((c) => ({
    label: `${content.pageTitle} in ${c.name}`,
    href: `/baraat-management/${slug}-${c.slug}`,
  }));
}
---

<Layout title={content.metaTitle} description={content.metaDescription}>
  {/* Hero Section */}
  <section class="relative overflow-hidden bg-[#FAF6F0] border-b border-black/10 py-16 text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4 relative z-10">
      <nav class="text-[10px] uppercase tracking-widest text-black/40 flex items-center justify-center gap-1.5">
        <a href="/" class="hover:text-[#E70D1D]">Home</a>
        <span>/</span>
        <a href="/baraat-management" class="hover:text-[#E70D1D]">Baraat Management</a>
        <span>/</span>
        {parent && <><a href={`/baraat-management/${parent.slug}`} class="hover:text-[#E70D1D]">{parent.name}</a><span>/</span></>}
        <span class="text-black/70">{loc ? loc.name : "Guide"}</span>
      </nav>

      <span class="text-[10px] uppercase tracking-widest font-bold text-[#E70D1D] block">
        {loc ? `${loc.name} Baraat Services` : "Baraat Procession Guide"}
      </span>

      <h1 class="font-serif font-black text-3xl md:text-5xl text-black tracking-wide leading-tight">
        {content.pageTitle}
      </h1>

      <p class="text-black/60 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
        {content.pageSubtitle}
      </p>

      <div class="pt-4">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
          Enquire on WhatsApp
        </a>
      </div>
    </div>
  </section>

  {/* Intro Section */}
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="space-y-4 text-stone-700 leading-relaxed text-[0.95rem]">
      {content.intro.split("\n\n").map((p) => (
        <p>{p}</p>
      ))}
    </div>
  </section>

  {/* Packages Section */}
  <section class="border-y border-black/10 bg-[#FAF6F0] py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto space-y-10">
      <div class="text-center space-y-1">
        <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Packages</span>
        <h2 class="font-serif font-black text-2xl md:text-3xl text-black tracking-wide">Choose Your Royal Experience</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {BARAAT_PACKAGES.map((pkg) => {
          const pkgWaText = encodeURIComponent(`Hi PlanMyBaraat! I'm interested in booking the ${pkg.name} Package for ${content.pageTitle}.`);
          const pkgWaLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${pkgWaText}`;
          return (
            <div class="border border-black/10 p-6 bg-white shadow-sm flex flex-col justify-between">
              <div class="space-y-3">
                <h3 class="font-serif font-black text-lg text-black">{pkg.name}</h3>
                <span class="text-[9px] uppercase font-bold tracking-widest text-[#E70D1D] block">{pkg.tagline}</span>
                <p class="text-xs text-black/50 mt-2 mb-4 leading-relaxed">{pkg.description}</p>
                <ul class="space-y-2">
                  {pkg.features.slice(0, 5).map((f) => (
                    <li class="flex items-start gap-2 text-xs text-black/70">
                      <span class="text-[#E70D1D] mt-0.5">✓</span>
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mt-6 pt-4 border-t border-black/5">
                <a href={pkgWaLink} target="_blank" rel="noopener noreferrer" class="w-full inline-flex items-center justify-center h-10 bg-black hover:bg-[#E70D1D] text-white font-extrabold uppercase tracking-widest text-[10px] transition-colors">
                  Enquire Now
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* Body Sections */}
  {sections.map((section, idx) => (
    <section class={`py-14 px-4 sm:px-6 lg:px-8 ${idx % 2 === 1 ? "bg-[#FAF6F0] border-y border-black/5" : ""}`}>
      <div class="max-w-2xl mx-auto space-y-3">
        <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">{section.eyebrow}</span>
        <h2 class="font-serif font-black text-2xl text-black tracking-wide">{section.heading}</h2>
        <div class="space-y-4 text-stone-700 leading-relaxed text-[0.95rem] pt-2">
          {section.body.split("\n\n").map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </div>
    </section>
  ))}

  {/* FAQs Accordion */}
  <section class="border-t border-black/10 py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto space-y-8">
      <div class="text-center space-y-1">
        <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Questions</span>
        <h2 class="font-serif font-black text-2xl text-black tracking-wide">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-4">
        {content.faqs.map((faq, idx) => (
          <div class="border-b border-black/10 pb-4">
            <h3 class="font-serif font-bold text-base text-black flex justify-between items-center cursor-pointer py-2">
              <span>{faq.q}</span>
              <span class="text-[#E70D1D]">+</span>
            </h3>
            <p class="text-xs text-black/60 leading-relaxed pt-1 pl-1">
              {faq.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Closing CTA */}
  <section class="bg-black text-white py-16 text-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-xl mx-auto space-y-4">
      <h2 class="font-serif font-black text-2xl md:text-3xl text-white tracking-wide">
        Ready to plan your wedding entry?
      </h2>
      <p class="text-white/60 text-xs md:text-sm">{content.closing}</p>
      <div class="pt-4">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>

  {/* Related Links Mesh */}
  {relatedLinks.length > 0 && (
    <section class="border-t border-black/10 bg-[#f7f1ea] py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto space-y-4">
        <h3 class="font-serif font-bold text-base text-black">Explore Other Areas & Keywords</h3>
        <div class="flex flex-wrap gap-2 pt-2">
          {relatedLinks.map((link) => (
            <a href={link.href} class="text-xs px-3 py-1.5 border border-black/10 bg-white text-black/60 hover:border-[#E70D1D]/40 hover:text-[#E70D1D] transition-colors capitalize">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
