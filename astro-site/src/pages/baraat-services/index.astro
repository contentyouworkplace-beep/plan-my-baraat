---
import Layout from "../../layouts/Layout.astro";
import { BARAAT_KEYWORDS } from "../../data/baraatKeywords";

const categories = Array.from(new Set(BARAAT_KEYWORDS.map((k) => k.category)));
---

<Layout title="Baraat Services Guide | PlanMyBaraat" description="Everything included in a PlanMyBaraat package — DJ trucks, dhol, vintage cars, safa teams, entry effects, pricing, and booking answered.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 space-y-12">
    <div class="text-center space-y-3">
      <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Guide</span>
      <h1 class="font-serif font-black text-3xl md:text-5xl text-black tracking-wide">Baraat Services Guide</h1>
      <p class="text-black/60 text-sm max-w-2xl mx-auto">
        Browse by topic — every element of a PlanMyBaraat package explained, plus pricing and booking answers.
      </p>
    </div>

    {categories.map((cat) => (
      <div class="space-y-3">
        <h2 class="font-serif font-black text-lg text-black tracking-wide border-b border-black/10 pb-2">{cat}</h2>
        <div class="flex flex-wrap gap-2">
          {BARAAT_KEYWORDS.filter((k) => k.category === cat).map((k) => (
            <a href={`/baraat-services/${k.slug}`} class="text-xs px-3 py-1.5 border border-black/10 text-black/60 hover:border-[#E70D1D]/40 hover:text-[#E70D1D] transition-colors capitalize">
              {k.phrase}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</Layout>
