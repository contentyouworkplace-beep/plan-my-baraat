---
import Layout from "../../layouts/Layout.astro";
import { ALL_BARAAT_LOCATIONS, getLocationBySlug } from "../../data/baraatLocations";
import { BARAAT_PACKAGES } from "../../data/packagesData";
import { WHATSAPP_NUMBER } from "../../data/whatsapp";
import { locationIntro, locationWhyUs, locationClosing } from "../../data/baraatContentVariants";

export function getStaticPaths() {
  return ALL_BARAAT_LOCATIONS.map((l) => ({ params: { location: l.slug } }));
}

const { location } = Astro.params;
const loc = getLocationBySlug(location!);
if (!loc) return Astro.redirect("/404");

const parent = loc.parentCity ? ALL_BARAAT_LOCATIONS.find((l) => l.slug === loc.parentCity && l.type === "city") : undefined;
const regionPhrase = parent ? `in ${loc.name}, ${parent.name}` : `in ${loc.name}`;
const displayRegion = parent ? `${loc.name}, ${parent.name}` : `${loc.name}, ${loc.state}`;

const waText = encodeURIComponent(
  `Hi PlanMyBaraat! 🎊\n\nI'm looking for baraat package services in ${loc.name}${parent ? `, ${parent.name}` : ""}. Please share package details and availability.`
);
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;

const title = `Baraat Package Services in ${loc.name} | PlanMyBaraat`;
const description = `DJ truck, dhol team, vintage car, and safa styling for your baraat in ${loc.name}, ${loc.state}. Four curated packages, one WhatsApp enquiry.`;
---

<Layout title={title} description={description}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-8 text-center space-y-4">
    <nav class="text-[10px] uppercase tracking-widest text-black/40 flex items-center justify-center gap-1.5">
      <a href="/" class="hover:text-[#E70D1D]">Home</a>
      <span>/</span>
      {parent && <><a href={`/baraat/${parent.slug}`} class="hover:text-[#E70D1D]">{parent.name}</a><span>/</span></>}
      <span class="text-black/70">{loc.name}</span>
    </nav>

    <span class="text-[10px] uppercase tracking-widest font-bold text-[#E70D1D] block">{displayRegion}</span>

    <h1 class="font-serif font-black text-3xl md:text-5xl text-black tracking-wide">
      Baraat Package Services {regionPhrase}
    </h1>

    <p class="text-black/60 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
      {locationIntro(loc.slug, { name: loc.name, region: regionPhrase, tier: loc.type })}
    </p>

    <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
      Enquire on WhatsApp
    </a>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <div class="text-center space-y-1">
      <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Our Packages</span>
      <h2 class="font-serif font-black text-2xl md:text-3xl text-black tracking-wide">Choose Your Royal Experience {regionPhrase}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {BARAAT_PACKAGES.map((pkg) => (
        <div class="border border-black/10 p-6 bg-white shadow-sm">
          <h3 class="font-serif font-black text-lg text-black">{pkg.name}</h3>
          <span class="text-[10px] uppercase font-bold tracking-widest text-[#E70D1D]">{pkg.tagline}</span>
          <p class="text-xs text-black/50 mt-2 mb-4">{pkg.description}</p>
          <ul class="space-y-2">
            {pkg.features.slice(0, 4).map((f) => (
              <li class="flex items-start gap-2 text-xs text-black/70">
                <span class="text-[#E70D1D] mt-0.5">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-4">
    <h2 class="font-serif font-black text-xl md:text-2xl text-black tracking-wide">Why Families {regionPhrase} Choose PlanMyBaraat</h2>
    <p class="text-black/60 text-sm leading-relaxed">
      {locationWhyUs(loc.slug, { name: loc.name, region: regionPhrase, tier: loc.type })}
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center space-y-4">
    <p class="text-black/70 text-sm">{locationClosing(loc.slug, { name: loc.name, region: regionPhrase, tier: loc.type })}</p>
    <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
      Chat on WhatsApp
    </a>
  </section>
</Layout>
