---
import Layout from "../../layouts/Layout.astro";
import { BARAAT_CITIES, BARAAT_AREAS, BARAAT_TOWNS } from "../../data/baraatLocations";
---

<Layout title="Baraat Package Locations | PlanMyBaraat" description="Find PlanMyBaraat's baraat package services across Gujarat, Mumbai, Delhi NCR and Bengaluru — city by city, area by area.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 space-y-12">
    <div class="text-center space-y-3">
      <span class="text-[9px] uppercase text-[#E70D1D] font-bold tracking-widest block">Service Areas</span>
      <h1 class="font-serif font-black text-3xl md:text-5xl text-black tracking-wide">Where We Deliver Baraats</h1>
      <p class="text-black/60 text-sm max-w-2xl mx-auto">
        Browse by city to see the specific areas we cover, or find your town below.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {BARAAT_CITIES.map((c) => {
        const areasForCity = BARAAT_AREAS.filter((a) => a.parentCity === c.slug);
        return (
          <div class="border border-black/10 p-5 space-y-3">
            <a href={`/baraat/${c.slug}`} class="font-serif font-black text-base text-black hover:text-[#E70D1D] transition-colors block">
              {c.name}
            </a>
            <p class="text-[10px] text-black/40 uppercase tracking-widest">{c.state}</p>
            {areasForCity.length > 0 && (
              <div class="flex flex-wrap gap-1.5 pt-1">
                {areasForCity.slice(0, 6).map((a) => (
                  <a href={`/baraat/${a.slug}`} class="text-[10px] px-2 py-1 border border-black/10 text-black/60 hover:border-[#E70D1D]/40 hover:text-[#E70D1D] transition-colors">
                    {a.name}
                  </a>
                ))}
                {areasForCity.length > 6 && (
                  <a href={`/baraat/${c.slug}`} class="text-[10px] px-2 py-1 text-[#E70D1D] font-bold">
                    +{areasForCity.length - 6} more
                  </a>
                )}
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="space-y-3">
      <h2 class="font-serif font-black text-lg text-black tracking-wide">Also Serving</h2>
      <div class="flex flex-wrap gap-2">
        {BARAAT_TOWNS.map((t) => (
          <a href={`/baraat/${t.slug}`} class="text-xs px-3 py-1.5 border border-black/10 text-black/60 hover:border-[#E70D1D]/40 hover:text-[#E70D1D] transition-colors">
            {t.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
