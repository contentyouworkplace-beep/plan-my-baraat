---
import Layout from "../layouts/Layout.astro";
import PackageCard from "../components/PackageCard.astro";
import { BARAAT_PACKAGES } from "../data/packagesData";
import { SITE_IMAGES } from "../data/siteImages";
import { ABOUT_POINTS, TESTIMONIALS, CONTACT_DETAILS, GALLERY_IMAGES, GALLERY_VIDEOS } from "../data/siteContent";
import { getHomeMeta } from "../data/seoMeta";

const STATS = [
  { value: "500+", label: "Baraats Organized" },
  { value: "6", label: "Cities Covered" },
  { value: "4.9/5", label: "Average Rating" },
  { value: "5 Yrs", label: "In Business" },
];

const STEPS = [
  { title: "Pick a Package", text: "Browse Raj Tilak, Rajwada, Maharaja or Signature and shortlist what fits your celebration." },
  { title: "Share Venue & Budget", text: "Send your venue name, city and budget range on WhatsApp so we can guide the right setup faster." },
  { title: "Customize & Confirm", text: "We tailor the truck branding, dhol count, lights and effects to your baraat, then lock the date." },
];

const meta = getHomeMeta();
---

<Layout title={meta.title} description={meta.description}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 opacity-40">
      <img src={SITE_IMAGES.traditionalCouple} alt="" class="h-full w-full object-cover grayscale" />
    </div>
    <div class="absolute inset-0 bg-white/80"></div>
    <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8 md:py-24">
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2.5 border border-[#E70D1D]/30 px-5 py-1.5 text-[10px] font-bold uppercase tracking-widest text-[#E70D1D] md:text-[11px]">
          Gujarat's Trusted Baraat Specialists
        </div>

        <h1 class="font-serif text-4xl font-black leading-tight tracking-wide text-black sm:text-5xl md:text-6xl">
          Your Baraat.<br />
          <span class="text-[#E70D1D]">Royally Reimagined.</span>
        </h1>

        <p class="mx-auto max-w-lg text-sm leading-relaxed text-black/60 lg:mx-0 md:text-base">
          Double-decker DJ trucks, dhol, pyro, vintage cars and safa teams — assembled into four ready-made
          packages so your entry is unforgettable and your planning is effortless.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4 pt-2 lg:justify-start">
          <a href="#packages" class="inline-flex h-12 items-center gap-2.5 bg-[#E70D1D] px-8 text-xs font-extrabold uppercase tracking-widest text-white transition-all duration-300 hover:bg-[#c40d1a]">
            Explore Packages
          </a>
        </div>
      </div>

      <div class="relative h-[360px] sm:h-[420px] lg:h-[480px]">
        <div class="absolute right-0 top-0 h-[78%] w-[72%] overflow-hidden border border-[#E70D1D]/25">
          <img src={SITE_IMAGES.heroMain} alt="Royal Indian wedding celebration" class="h-full w-full object-cover grayscale-[15%]" />
        </div>
        <div class="absolute bottom-0 left-0 h-[55%] w-[58%] overflow-hidden border border-[#E70D1D]/25">
          <img src={SITE_IMAGES.heroFloral} alt="Gold floral wedding decor" class="h-full w-full object-cover grayscale-[15%]" />
        </div>
        <div class="absolute bottom-6 right-4 flex items-center gap-3 border border-[#E70D1D]/30 bg-white px-5 py-3.5 shadow-md">
          <div>
            <p class="font-serif text-sm font-black leading-none text-black">500+ Baraats</p>
            <p class="mt-1 text-[9px] uppercase tracking-widest text-black/40">Delivered Since 2021</p>
          </div>
        </div>
        <p class="absolute bottom-0 right-4 translate-y-[calc(100%+10px)] text-right text-[9px] font-bold uppercase tracking-widest text-black/40">
          Proudly Serving the Wedding Industry Since Our 3rd Generation
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-black/10 bg-[#F7F7F7]">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-6 px-4 py-10 sm:px-6 lg:px-8 md:grid-cols-4">
      {STATS.map((s) => (
        <div class="flex flex-col items-center gap-2 text-center">
          <span class="font-serif text-xl font-black text-black md:text-2xl">{s.value}</span>
          <span class="text-[9px] font-bold uppercase tracking-widest text-black/40">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section id="about" class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8">
    <div class="relative order-2 h-[300px] sm:h-[380px] lg:order-1 lg:h-[440px]">
      <div class="absolute inset-0 overflow-hidden border border-[#E70D1D]/25">
        <img src={SITE_IMAGES.goldCrownMoment} alt="PlanMyBaraat team at a wedding celebration" class="h-full w-full object-cover grayscale-[15%]" />
      </div>
    </div>

    <div class="order-1 space-y-6 lg:order-2">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">About Us</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">
        Gujarat's Trusted Name in Baraat Celebrations
      </h2>
      <p class="text-sm leading-relaxed text-black/60">
        PlanMyBaraat by Ronak brings together everything a groom's entry needs — double-decker DJ trucks,
        vintage cars, dhol artists, pyro effects, and safa teams — under one roof, so families can focus on
        celebrating instead of coordinating five different vendors.
      </p>
      <ul class="space-y-3">
        {ABOUT_POINTS.map((point) => (
          <li class="flex items-start gap-3 text-xs text-black/70">
            <span class="mt-0.5 text-[#E70D1D]">✓</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
      <a href="/about" class="inline-flex h-11 items-center gap-2.5 border border-black/20 px-6 text-xs font-extrabold uppercase tracking-widest text-black transition-all duration-300 hover:border-[#E70D1D]/50 hover:text-[#E70D1D]">
        Read Our Story
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-7xl space-y-10 px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-1 text-center">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">Simple Process</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">How It Works</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {STEPS.map((step, i) => (
        <div class="relative border border-black/10 bg-white p-7 shadow-sm">
          <span class="absolute -left-2 -top-4 font-serif text-5xl font-black text-black/5">0{i + 1}</span>
          <h3 class="relative z-10 font-serif text-lg font-black text-black">{step.title}</h3>
          <p class="relative z-10 mt-2 text-xs leading-relaxed text-black/50">{step.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="packages" class="mx-auto max-w-7xl space-y-8 px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-1 text-center">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">Curated Baraat Packages</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">Choose Your Royal Experience</h2>
      <p class="mx-auto max-w-2xl pt-2 text-xs text-black/50 md:text-sm">
        Every package can be customized — enquire on WhatsApp with your venue name, city and budget range to get a
        personalized quote and availability.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      {BARAAT_PACKAGES.map((pkg, i) => (
        <PackageCard pkg={pkg} featured={i === 2} />
      ))}
    </div>
  </section>

  <section id="gallery" class="mx-auto max-w-7xl space-y-8 px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-1 text-center">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">Moments We Love</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">From Real Celebrations</h2>
    </div>

    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-5">
      {GALLERY_IMAGES.slice(0, 5).map((g, i) => (
        <div class={`group relative overflow-hidden border border-black/10 ${i === 0 ? "col-span-2 row-span-2 aspect-square md:aspect-auto md:h-full" : "aspect-square"}`}>
          <img src={g.src} alt={g.label} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
          <span class="absolute bottom-3 left-3 text-[10px] font-bold uppercase tracking-widest text-white">{g.label}</span>
        </div>
      ))}

      <div class="group relative aspect-square overflow-hidden border border-black/10 bg-[#F7F7F7]">
        <img src={GALLERY_VIDEOS[0].thumb} alt={GALLERY_VIDEOS[0].label} class="h-full w-full object-cover opacity-50 transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[#E70D1D]">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white"><polygon points="6 3 20 12 6 21 6 3"/></svg>
          </div>
        </div>
        <span class="absolute right-3 top-3 bg-black/60 px-2 py-0.5 text-[9px] font-bold text-white">{GALLERY_VIDEOS[0].duration}</span>
        <span class="absolute bottom-3 left-3 text-[10px] font-bold uppercase tracking-widest text-white">{GALLERY_VIDEOS[0].label}</span>
      </div>
    </div>

    <div class="text-center">
      <a href="/gallery" class="inline-flex h-12 items-center gap-2.5 border border-black/20 px-8 text-xs font-extrabold uppercase tracking-widest text-black transition-all duration-300 hover:border-[#E70D1D]/50 hover:text-[#E70D1D]">
        View Full Gallery
      </a>
    </div>
  </section>

  <section id="testimonials" class="mx-auto max-w-7xl space-y-8 px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-1 text-center">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">What Families Say</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">Testimonials</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {TESTIMONIALS.slice(0, 3).map((t) => (
        <div class="relative flex flex-col overflow-hidden border border-black/10 bg-white p-8 text-center shadow-sm">
          <p class="flex-1 font-serif text-xs italic leading-relaxed text-black/80 md:text-sm">"{t.quote}"</p>
          <div class="mt-5 text-[10px] font-bold uppercase tracking-widest text-[#E70D1D]">{t.name} • {t.place}</div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a href="/testimonials" class="inline-flex h-12 items-center gap-2.5 border border-black/20 px-8 text-xs font-extrabold uppercase tracking-widest text-black transition-all duration-300 hover:border-[#E70D1D]/50 hover:text-[#E70D1D]">
        View All Testimonials
      </a>
    </div>
  </section>

  <section id="contact" class="mx-auto max-w-7xl space-y-10 px-4 py-16 sm:px-6 lg:px-8">
    <div class="space-y-1 text-center">
      <span class="block text-[9px] font-bold uppercase tracking-widest text-[#E70D1D]">Get In Touch</span>
      <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">Contact Us</h2>
      <p class="mx-auto max-w-2xl pt-2 text-xs text-black/50 md:text-sm">
        Have a question before you enquire? Reach us directly — we usually reply within minutes on WhatsApp.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {CONTACT_DETAILS.map((c) => (
        <div class="space-y-3 border border-black/10 bg-white p-6 shadow-sm">
          <span class="block text-[9px] font-bold uppercase tracking-widest text-black/40">{c.label}</span>
          {"href" in c ? (
            <a href={c.href} target="_blank" rel="noopener noreferrer" class="block text-xs leading-relaxed text-black/80 transition-colors hover:text-[#E70D1D]">{c.value}</a>
          ) : (
            <p class="text-xs leading-relaxed text-black/80">{c.value}</p>
          )}
        </div>
      ))}
    </div>

    <div class="text-center">
      <a href="https://wa.me/918830612287" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2.5 bg-[#E70D1D] px-8 text-xs font-extrabold uppercase tracking-widest text-white transition-all duration-300 hover:bg-[#c40d1a]">
        Chat With Us on WhatsApp
      </a>
    </div>
  </section>

  <section class="relative overflow-hidden">
    <div class="relative h-[280px] md:h-[340px]">
      <img src={SITE_IMAGES.ctaBanner} alt="Book your baraat celebration" class="h-full w-full object-cover grayscale-[30%]" />
      <div class="absolute inset-0 bg-white/85"></div>
      <div class="absolute inset-0 flex items-center">
        <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
          <div class="space-y-2 text-center md:text-left">
            <h2 class="font-serif text-2xl font-black tracking-wide text-black md:text-4xl">Ready to Plan Your Baraat?</h2>
            <p class="text-xs text-black/60 md:text-sm">Tell us your venue name, city and budget range — we'll take it from there.</p>
          </div>
          <a href="#packages" class="mx-auto inline-flex h-12 items-center justify-center gap-2.5 bg-[#E70D1D] px-8 text-xs font-extrabold uppercase tracking-widest text-white transition-all duration-300 hover:bg-[#c40d1a] md:mx-0">
            Enquire Now
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
