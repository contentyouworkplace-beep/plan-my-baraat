---
import Layout from "../layouts/Layout.astro";
import PackageCard from "../components/PackageCard.astro";
import EnquiryModal from "../components/EnquiryModal.astro";
import { BARAAT_PACKAGES } from "../data/packagesData";
import { SITE_IMAGES } from "../data/siteImages";
import { ABOUT_POINTS, TESTIMONIALS, CONTACT_DETAILS, GALLERY_IMAGES, GALLERY_VIDEOS } from "../data/siteContent";
import { getHomeMeta } from "../data/seoMeta";

const STATS = [
  { value: "500+", label: "Baraats Organized" },
  { value: "6", label: "Cities Covered" },
  { value: "4.9/5", label: "Average Rating" },
  { value: "5 Yrs", label: "In Business" },
];

const STEPS = [
  {
    title: "Pick Your Package",
    text: "Choose the baraat style that fits your family, budget, guest count and venue flow.",
  },
  {
    title: "Share Venue & Budget",
    text: "Send your venue name, city, date and budget range on WhatsApp for a sharper quote.",
  },
  {
    title: "Lock the Experience",
    text: "We align dhol, DJ truck, entry timing, safa team and special effects into one managed plan.",
  },
];

const meta = getHomeMeta();
---

<Layout title={meta.title} description={meta.description}>
  <section class="section-shell relative overflow-hidden">
    <div class="hero-orb hero-orb--gold h-56 w-56 -left-20 top-20"></div>
    <div class="hero-orb hero-orb--rose h-72 w-72 right-0 top-12"></div>
    <div class="absolute inset-0 royal-grid opacity-[0.16]"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-18 md:pt-20 md:pb-24 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-12 items-center">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-3 rounded-full border border-[rgba(184,134,11,0.22)] bg-white/75 px-4 py-2 text-[11px] uppercase tracking-[0.22em] font-bold text-[#8c6200] shadow-[0_18px_38px_-28px_rgba(184,134,11,0.65)]">
            <span>Vadodara Based</span>
            <span class="h-1.5 w-1.5 rounded-full bg-[#9f1239]"></span>
            <span>Serving Gujarat Weddings</span>
          </div>

          <div class="space-y-4">
            <p class="text-[11px] uppercase tracking-[0.3em] font-bold text-[#9f1239]">Premium Baraat Planning</p>
            <h1 class="font-serif text-4xl sm:text-5xl xl:text-6xl leading-[1.05] text-[#1c1917] max-w-3xl">
              Your baraat deserves a grand arrival.
              <span class="block gold-text-shimmer mt-2">We plan it with precision and style.</span>
            </h1>
            <p class="text-base md:text-lg text-black/65 leading-8 max-w-2xl">
              PlanMyBaraat creates premium baraat packages in Vadodara, Ahmedabad, Surat and across Gujarat with
              DJ truck entries, vintage cars, live dhol, safa teams, pyro effects and one-point coordination.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <a href="#packages" class="inline-flex items-center justify-center h-13 px-8 rounded-full bg-[#9f1239] hover:bg-[#7e1535] text-white text-xs md:text-sm font-bold uppercase tracking-[0.18em] shadow-[0_20px_40px_-22px_rgba(159,18,57,0.9)]">
              Explore Packages
            </a>
            <a href="/baraat-management" class="inline-flex items-center justify-center h-13 px-8 rounded-full border border-[rgba(184,134,11,0.28)] bg-white/75 text-[#1c1917] hover:text-[#9f1239] hover:border-[rgba(159,18,57,0.3)] text-xs md:text-sm font-bold uppercase tracking-[0.18em]">
              View Keyword Pages
            </a>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-2">
            {STATS.map((s) => (
              <div class="glass-panel rounded-[24px] p-5 text-center">
                <div class="font-serif text-2xl md:text-3xl text-[#1c1917]">{s.value}</div>
                <div class="mt-2 text-[10px] uppercase tracking-[0.22em] font-bold text-black/45">{s.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative min-h-[520px]">
          <div class="glass-panel rounded-[32px] p-4 md:p-5 absolute top-0 right-0 w-[78%] md:w-[72%]">
            <div class="overflow-hidden rounded-[26px] aspect-[4/5]">
              <img src={SITE_IMAGES.heroMain} alt="Premium baraat setup in Gujarat" class="w-full h-full object-cover" />
            </div>
          </div>

          <div class="glass-panel rounded-[28px] p-3 absolute left-0 bottom-16 w-[54%]">
            <div class="overflow-hidden rounded-[22px] aspect-[4/3]">
              <img src={SITE_IMAGES.heroFloral} alt="Royal baraat floral styling" class="w-full h-full object-cover" />
            </div>
          </div>

          <div class="absolute left-[8%] top-[16%] glass-panel rounded-[24px] px-5 py-4 max-w-[220px]">
            <div class="text-[10px] uppercase tracking-[0.22em] font-bold text-[#9f1239]">Managed Entry Flow</div>
            <p class="mt-2 text-sm leading-6 text-black/65">
              DJ truck, dhol, car, groom timing and venue movement planned as one smooth sequence.
            </p>
          </div>

          <div class="absolute right-2 bottom-0 glass-panel rounded-[24px] px-5 py-4 max-w-[240px]">
            <div class="text-[10px] uppercase tracking-[0.22em] font-bold text-[#8c6200]">Venue First Planning</div>
            <p class="mt-2 text-sm leading-6 text-black/65">
              Built for city weddings, venue movement, guest flow and memorable groom entries across Gujarat.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="glass-panel rounded-[32px] p-8 md:p-10 grid grid-cols-1 lg:grid-cols-[0.9fr_1.1fr] gap-10 items-center">
      <div class="overflow-hidden rounded-[28px] aspect-[4/5] md:aspect-[4/4.6]">
        <img src={SITE_IMAGES.goldCrownMoment} alt="Groom royal entry moment" class="w-full h-full object-cover" />
      </div>

      <div class="space-y-6">
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">Why Families Book Us</p>
          <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] leading-tight mt-3">
            We don’t just send vendors. We manage the full baraat experience.
          </h2>
        </div>

        <p class="text-base text-black/65 leading-8">
          Families across Vadodara and Gujarat come to PlanMyBaraat when they want one responsible team for
          the full entry experience instead of coordinating multiple suppliers on a high-pressure wedding day.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {ABOUT_POINTS.map((point) => (
            <div class="rounded-[22px] border border-[rgba(184,134,11,0.16)] bg-white/70 p-5">
              <div class="flex items-start gap-3">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-[#9f1239]"></span>
                <p class="text-sm leading-7 text-black/70">{point}</p>
              </div>
            </div>
          ))}
        </div>

        <a href="/about" class="inline-flex items-center justify-center h-12 px-7 rounded-full border border-[rgba(184,134,11,0.24)] bg-white/75 text-[#1c1917] hover:text-[#9f1239] hover:border-[rgba(159,18,57,0.28)] text-xs font-bold uppercase tracking-[0.18em]">
          Read Our Story
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-12">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">How It Works</p>
      <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] mt-3">A simpler booking flow for a bigger baraat impact</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
      {STEPS.map((step, index) => (
        <div class="glass-panel glass-panel-hover rounded-[28px] p-7 relative overflow-hidden">
          <span class="absolute right-5 top-3 font-serif text-6xl text-[#b8860b]/12">0{index + 1}</span>
          <p class="text-[11px] uppercase tracking-[0.24em] font-bold text-[#8c6200]">Step {index + 1}</p>
          <h3 class="font-serif text-2xl text-[#1c1917] mt-3">{step.title}</h3>
          <p class="text-sm text-black/65 leading-7 mt-4">{step.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="packages" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-8">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">Baraat Packages in Gujarat</p>
      <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] mt-3">Choose a package, then customize it for your venue and city</h2>
      <p class="text-base text-black/60 leading-8 mt-4">
        Each package is structured for search intent and real bookings: price-aware, city-relevant and ready
        for WhatsApp enquiries with venue name and budget range.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {BARAAT_PACKAGES.map((pkg, i) => (
        <PackageCard pkg={pkg} featured={i === 2} />
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 items-start">
      <div class="space-y-5">
        <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">Gallery Preview</p>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] leading-tight">
          Real visual mood from baraats, venue entries and groom celebrations
        </h2>
        <p class="text-base text-black/60 leading-8">
          Browse moments inspired by real celebrations, venue styling and grand baraat entries across Vadodara,
          Ahmedabad, Surat and destination weddings in Gujarat.
        </p>
        <a href="/gallery" class="inline-flex items-center justify-center h-12 px-7 rounded-full bg-[#1c1917] hover:bg-[#9f1239] text-white text-xs font-bold uppercase tracking-[0.18em]">
          View Full Gallery
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {GALLERY_IMAGES.slice(0, 4).map((g, index) => (
          <div class={`overflow-hidden rounded-[26px] ${index === 0 ? "col-span-2 aspect-[16/9]" : "aspect-square"} shadow-[0_24px_50px_-28px_rgba(0,0,0,0.45)]`}>
            <img src={g.src} alt={g.label} class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" />
          </div>
        ))}
        <div class="col-span-2 glass-panel rounded-[28px] p-5 flex items-center justify-between gap-4">
          <div>
            <p class="text-[11px] uppercase tracking-[0.24em] font-bold text-[#8c6200]">{GALLERY_VIDEOS[0].label}</p>
            <p class="text-sm text-black/60 mt-2">Short-form venue and baraat highlights built for trust, proof and conversion.</p>
          </div>
          <div class="shrink-0 h-14 w-14 rounded-full bg-[#9f1239] text-white flex items-center justify-center text-xl">▶</div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">Testimonials</p>
      <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] mt-3">Families remember the coordination as much as the entry</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
      {TESTIMONIALS.slice(0, 3).map((t) => (
        <div class="glass-panel glass-panel-hover rounded-[28px] p-7 flex flex-col">
          <p class="font-serif text-lg leading-8 text-[#1c1917]">“{t.quote}”</p>
          <p class="mt-6 text-[11px] uppercase tracking-[0.22em] font-bold text-[#9f1239]">{t.name}</p>
          <p class="mt-1 text-sm text-black/50">{t.place}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-18">
    <div class="glass-panel rounded-[34px] overflow-hidden grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="p-8 md:p-10 lg:p-12 space-y-5">
        <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#9f1239]">Contact & Booking</p>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1c1917] leading-tight">Share your venue name, city and budget. We’ll guide the rest.</h2>
        <p class="text-base text-black/60 leading-8">
          Tell us your venue name, city, preferred package and budget range. We will suggest the best entry flow,
          required elements and package fit for your celebration.
        </p>
        <div class="space-y-4">
          {CONTACT_DETAILS.map((c) => (
            <div class="rounded-[22px] border border-[rgba(184,134,11,0.16)] bg-white/70 px-5 py-4">
              <p class="text-[10px] uppercase tracking-[0.22em] font-bold text-[#8c6200]">{c.label}</p>
              {"href" in c ? (
                <a href={c.href} target="_blank" rel="noopener noreferrer" class="block mt-2 text-sm text-black/70 hover:text-[#9f1239] break-words">
                  {c.value}
                </a>
              ) : (
                <p class="mt-2 text-sm text-black/70 leading-7">{c.value}</p>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="relative min-h-[360px] lg:min-h-full">
        <img src={SITE_IMAGES.ctaBanner} alt="Royal wedding venue in Gujarat" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-br from-[#1c1917]/30 via-[#9f1239]/30 to-[#b8860b]/20"></div>
        <div class="absolute inset-0 p-8 md:p-10 lg:p-12 flex items-end">
          <div class="glass-panel rounded-[28px] p-6 max-w-md">
            <p class="text-[10px] uppercase tracking-[0.22em] font-bold text-[#9f1239]">Plan With Clarity</p>
            <p class="mt-3 text-sm leading-7 text-black/70">
              From package browsing to venue-specific enquiries, every step is designed to make booking your
              baraat faster, clearer and more premium.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <EnquiryModal />
</Layout>
