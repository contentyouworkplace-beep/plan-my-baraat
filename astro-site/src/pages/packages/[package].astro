---
import Layout from "../../layouts/Layout.astro";
import { BARAAT_PACKAGES } from "../../data/packagesData";
import { getPackageDetail } from "../../data/packageDetails";
import { WHATSAPP_NUMBER } from "../../data/whatsapp";
import { getPackageMeta } from "../../data/seoMeta";

export function getStaticPaths() {
  return BARAAT_PACKAGES.map((pkg) => ({ params: { package: pkg.id } }));
}

const { package: pkgId } = Astro.params;
const pkg = BARAAT_PACKAGES.find((p) => p.id === pkgId);
if (!pkg) return Astro.redirect("/404");
const detail = getPackageDetail(pkg.id);

const otherPackages = BARAAT_PACKAGES.filter((p) => p.id !== pkg.id);

const waText = encodeURIComponent(
  `Hi PlanMyBaraat! 🎊\n\nI'm interested in the *${pkg.name}*. Please share more details and availability!`
);
const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;

const meta = getPackageMeta(pkg);
---

<Layout title={meta.title} description={meta.description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-8 text-center space-y-4">
    <nav class="text-[10px] uppercase tracking-widest text-black/40 flex items-center justify-center gap-1.5">
      <a href="/" class="hover:text-[#E70D1D]">Home</a>
      <span>/</span>
      <a href="/packages" class="hover:text-[#E70D1D]">Packages</a>
      <span>/</span>
      <span class="text-black/70">{pkg.name}</span>
    </nav>

    <span class="text-[10px] uppercase tracking-widest font-bold text-[#E70D1D] block">{pkg.tagline}</span>
    <h1 class="font-serif font-black text-3xl md:text-5xl text-black tracking-wide">{pkg.name}</h1>
    <p class="text-black/60 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">{pkg.description}</p>

    <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
      Enquire on WhatsApp
    </a>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-4">
    <h2 class="font-serif font-black text-xl md:text-2xl text-black tracking-wide">What's Included</h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
      {pkg.features.map((f) => (
        <li class="flex items-start gap-2.5 text-sm text-black/75">
          <span class="text-[#E70D1D] mt-0.5 font-bold">✓</span>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  </section>

  {detail && (
    <>
      <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-4 border-t border-black/10">
        <h2 class="font-serif font-black text-xl md:text-2xl text-black tracking-wide">Who This Package Is For</h2>
        <p class="text-black/60 text-sm leading-relaxed">{detail.idealFor}</p>
      </section>

      <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-4 border-t border-black/10">
        <h2 class="font-serif font-black text-xl md:text-2xl text-black tracking-wide">How It Compares</h2>
        <p class="text-black/60 text-sm leading-relaxed">{detail.positioning}</p>
      </section>

      <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-6 border-t border-black/10">
        <h2 class="font-serif font-black text-xl md:text-2xl text-black tracking-wide">Common Questions</h2>
        <div class="space-y-5">
          {detail.faqs.map((faq) => (
            <div>
              <h3 class="font-bold text-sm text-black">{faq.q}</h3>
              <p class="text-black/60 text-sm leading-relaxed mt-1">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-black/10 space-y-6">
    <h2 class="font-serif font-black text-lg text-black tracking-wide text-center">Compare Other Packages</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {otherPackages.map((p) => (
        <a href={`/packages/${p.id}`} class="border border-black/10 p-5 hover:border-[#E70D1D]/40 transition-colors block">
          <h3 class="font-serif font-black text-base text-black">{p.name}</h3>
          <span class="text-[10px] uppercase font-bold tracking-widest text-[#E70D1D]">{p.tagline}</span>
          <p class="text-xs text-black/50 mt-2">{p.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center">
    <a href={waLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 h-12 px-8 bg-[#E70D1D] hover:bg-[#c40d1a] text-white font-extrabold uppercase tracking-widest text-xs transition-all duration-300">
      Get a Quote for {pkg.name} on WhatsApp
    </a>
  </section>
</Layout>
